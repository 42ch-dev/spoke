{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/common/error-envelope.schema.json",
  "title": "ErrorEnvelope",
  "description": "Shared ops error shape. Ops responses use either a success payload or a top-level error field — not both.",
  "type": "object",
  "required": ["code", "message", "extensions"],
  "properties": {
    "code": {
      "type": "string",
      "description": "Machine-readable error code."
    },
    "message": {
      "type": "string",
      "description": "Human-readable error message."
    },
    "details": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional structured error context."
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap"
    }
  },
  "additionalProperties": false
}
