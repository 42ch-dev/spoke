{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/data/timeline-event.schema.json",
  "title": "TimelineEvent",
  "description": "First-class when-axis temporal object (L5). Distinct from KnowledgeEntry ontology labels such as entry_type: \"event\" (KB fact node, not this wire type).",
  "type": "object",
  "required": [
    "schema_version",
    "timeline_event_id",
    "canonical_name",
    "extensions"
  ],
  "properties": {
    "schema_version": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "timeline_event_id": {
      "type": "string",
      "description": "Stable TimelineEvent id (opaque to protocol)."
    },
    "canonical_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-stable label."
    },
    "timeline_scale": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/TimelineScale",
      "description": "Optional L5 projection tier (brief, narrative, moment)."
    },
    "occurred_at": {
      "type": "string",
      "description": "When the event happened — RFC 3339 or opaque fuzzy label (e.g. Third Age)."
    },
    "description": {
      "type": "string",
      "description": "Longer narrative summary."
    },
    "participant_entry_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Related KnowledgeEntry ids (characters, locations, etc.)."
    },
    "source_anchor": {
      "$ref": "https://spoke42.invalid/schemas/data/source-anchor.schema.json",
      "description": "Optional manuscript or scene anchor."
    },
    "sort_key": {
      "type": "string",
      "description": "Opaque ordering hint within a timeline (products define grammar)."
    },
    "fork_id": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ForkId",
      "description": "Optional world-history branch identity (l5-fork)."
    },
    "parent_fork_id": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ForkId",
      "description": "Optional parent/base branch reference when product records fork lineage on the event."
    },
    "computable_logs": {
      "type": "array",
      "items": {
        "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ComputableLogEntry"
      },
      "description": "Optional Moment-scale presentation of computable field change history (l2-computable only). Not Finding-shaped."
    },
    "created_at": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/Timestamp"
    },
    "updated_at": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/Timestamp"
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": 1,
      "timeline_event_id": "evt_01HXYZ",
      "canonical_name": "Treaty of Ashford",
      "timeline_scale": "narrative",
      "occurred_at": "1421-06-03T00:00:00Z",
      "participant_entry_ids": ["kb_mira", "kb_ashford"],
      "extensions": {
        "my_product": { "world_id": "wld_abc" }
      }
    },
    {
      "schema_version": 1,
      "timeline_event_id": "evt_fork_01HXYZ",
      "canonical_name": "Treaty of Ashford (what-if branch)",
      "timeline_scale": "narrative",
      "occurred_at": "1421-06-03T00:00:00Z",
      "fork_id": "fork_what_if_b",
      "parent_fork_id": "fork_mainline_a",
      "participant_entry_ids": ["kb_mira", "kb_ashford"],
      "extensions": {
        "my_product": { "world_id": "wld_abc" }
      }
    },
    {
      "schema_version": 1,
      "timeline_event_id": "evt_moment_01HXYZ",
      "canonical_name": "Harbor tide reading",
      "timeline_scale": "moment",
      "occurred_at": "2026-07-23T05:45:00Z",
      "participant_entry_ids": ["kb_harbor"],
      "computable_logs": [
        {
          "logged_at": "2026-07-23T05:50:00Z",
          "entry_id": "kb_harbor",
          "changes": [
            {
              "path": "tide_level",
              "previous": 2.1,
              "next": 2.4
            }
          ],
          "session_id": "sess_dawn_arrival",
          "message": "Tide projection updated at dock."
        }
      ],
      "extensions": {
        "my_product": { "world_id": "wld_abc" }
      }
    }
  ]
}
