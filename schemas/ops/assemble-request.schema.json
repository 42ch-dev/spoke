{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/assemble-request.schema.json",
  "title": "AssembleRequest",
  "description": "Selector hints for context assembly. Wire-only — no compute semantics.",
  "type": "object",
  "required": ["scope"],
  "properties": {
    "scope": {
      "$ref": "#/definitions/AssembleScope",
      "description": "Assembly scope selector."
    },
    "max_entries": {
      "type": "integer",
      "minimum": 1,
      "description": "Optional entry limit hint (not enforced by protocol)."
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
      "description": "Optional transport metadata."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AssembleScope": {
      "type": "object",
      "properties": {
        "keyblock_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional Keyblock ids to include."
        },
        "block_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional block_type filters."
        },
        "source_id": {
          "type": "string",
          "description": "Optional source locator scope."
        }
      },
      "additionalProperties": false
    }
  }
}
