{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/assemble-response.schema.json",
  "title": "AssembleResponse",
  "description": "Assemble success packet or wire error. Use packet OR error — not both.",
  "oneOf": [
    {
      "type": "object",
      "required": ["packet"],
      "properties": {
        "packet": {
          "$ref": "https://spoke42.invalid/schemas/data/assemble-packet.schema.json",
          "description": "Success: assembled context packet."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "$ref": "https://spoke42.invalid/schemas/common/error-envelope.schema.json",
          "description": "Failure: shared error envelope."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    }
  ]
}
