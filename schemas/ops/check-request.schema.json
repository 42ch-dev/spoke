{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/check-request.schema.json",
  "title": "CheckRequest",
  "description": "Run checker(s) over a scope; returns Finding(s).",
  "type": "object",
  "required": ["scope"],
  "properties": {
    "scope": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/Scope",
      "description": "Checker scope selector."
    },
    "rule_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Opaque rule ids or URIs. Resolved by receiver when not overridden by rules[]."
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "https://spoke42.invalid/schemas/data/rule.schema.json"
      },
      "description": "Optional embedded Rule objects for portable interchange."
    },
    "checker_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional checker kind filters."
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
      "description": "Optional transport metadata."
    }
  },
  "additionalProperties": false
}
