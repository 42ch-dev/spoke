{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/check-response.schema.json",
  "title": "CheckResponse",
  "description": "Checker findings or wire error. Use findings OR error — not both.",
  "oneOf": [
    {
      "type": "object",
      "required": ["findings"],
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "$ref": "https://spoke42.invalid/schemas/data/finding.schema.json"
          },
          "description": "Success: checker output findings."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "$ref": "https://spoke42.invalid/schemas/common/error-envelope.schema.json",
          "description": "Failure: shared error envelope."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    }
  ]
}
