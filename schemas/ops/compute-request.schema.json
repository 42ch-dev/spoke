{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/compute-request.schema.json",
  "title": "ComputeRequest",
  "description": "Apply / settle I/O — carry computable updates; merge to static state when settle is true.",
  "type": "object",
  "required": ["session_id", "entry_id", "computable"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Opaque Session correlation id. Products own Session stores."
    },
    "entry_id": {
      "type": "string",
      "description": "Target KnowledgeEntry id."
    },
    "computable": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ComputableFieldMap",
      "description": "Session-scoped dynamic computable payload (body.computable)."
    },
    "settle": {
      "type": "boolean",
      "description": "When true, product merges computable into static state at Session end. Defaults to false when omitted."
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
      "description": "Optional transport metadata."
    }
  },
  "additionalProperties": false
}
