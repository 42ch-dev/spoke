{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/promote-request.schema.json",
  "title": "PromoteRequest",
  "description": "Extract-to-promote: promote a candidate Keyblock to durable storage.",
  "type": "object",
  "required": ["candidate"],
  "properties": {
    "candidate": {
      "$ref": "https://spoke42.invalid/schemas/data/keyblock.schema.json",
      "description": "Candidate Keyblock (typically status provisional)."
    },
    "target_keyblock_id": {
      "type": "string",
      "description": "Optional merge target Keyblock id."
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
      "description": "Optional transport metadata."
    }
  },
  "additionalProperties": false
}
