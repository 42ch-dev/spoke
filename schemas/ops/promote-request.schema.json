{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/promote-request.schema.json",
  "title": "PromoteRequest",
  "description": "Extract-to-promote: promote a candidate KnowledgeEntry to durable storage.",
  "type": "object",
  "required": ["candidate"],
  "properties": {
    "candidate": {
      "$ref": "https://spoke42.invalid/schemas/data/knowledge-entry.schema.json",
      "description": "Candidate KnowledgeEntry (typically status provisional)."
    },
    "target_entry_id": {
      "type": "string",
      "description": "Optional merge target KnowledgeEntry id."
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
      "description": "Optional transport metadata."
    }
  },
  "additionalProperties": false
}
