{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/promote-response.schema.json",
  "title": "PromoteResponse",
  "description": "Promoted Keyblock or wire error. Use keyblock OR error — not both.",
  "oneOf": [
    {
      "type": "object",
      "required": ["keyblock"],
      "properties": {
        "keyblock": {
          "$ref": "https://spoke42.invalid/schemas/data/keyblock.schema.json",
          "description": "Success: promoted Keyblock."
        },
        "superseded_id": {
          "type": "string",
          "description": "Optional id of Keyblock superseded during merge."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "$ref": "https://spoke42.invalid/schemas/common/error-envelope.schema.json",
          "description": "Failure: shared error envelope."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    }
  ]
}
