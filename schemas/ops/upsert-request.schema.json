{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/upsert-request.schema.json",
  "title": "UpsertRequest",
  "description": "Create or update one or more Keyblocks by stable id.",
  "type": "object",
  "required": ["keyblocks"],
  "properties": {
    "keyblocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://spoke42.invalid/schemas/data/keyblock.schema.json"
      },
      "description": "Keyblocks to create or update."
    },
    "idempotency_key": {
      "type": "string",
      "description": "Opaque idempotency hint (no server semantics in v0.1)."
    },
    "extensions": {
      "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
      "description": "Optional transport metadata."
    }
  },
  "additionalProperties": false
}
