{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spoke42.invalid/schemas/ops/upsert-response.schema.json",
  "title": "UpsertResponse",
  "description": "Persisted KnowledgeEntry view or wire error. Use knowledge_entries OR error — not both.",
  "oneOf": [
    {
      "type": "object",
      "required": ["knowledge_entries"],
      "properties": {
        "knowledge_entries": {
          "type": "array",
          "items": {
            "$ref": "https://spoke42.invalid/schemas/data/knowledge-entry.schema.json"
          },
          "description": "Success: persisted KnowledgeEntries."
        },
        "rejected": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/UpsertRejected"
          },
          "description": "Optional per-KnowledgeEntry rejections (success branch only)."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "$ref": "https://spoke42.invalid/schemas/common/error-envelope.schema.json",
          "description": "Failure: shared error envelope."
        },
        "extensions": {
          "$ref": "https://spoke42.invalid/schemas/common/common.schema.json#/definitions/ExtensionMap",
          "description": "Optional transport metadata."
        }
      },
      "additionalProperties": false
    }
  ],
  "definitions": {
    "UpsertRejected": {
      "type": "object",
      "required": ["entry_id", "code", "message"],
      "properties": {
        "entry_id": {
          "type": "string",
          "description": "Rejected KnowledgeEntry id."
        },
        "code": {
          "type": "string",
          "description": "Machine-readable rejection code."
        },
        "message": {
          "type": "string",
          "description": "Human-readable rejection message."
        }
      },
      "additionalProperties": false
    }
  }
}
